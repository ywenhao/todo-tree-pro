{
  "name": "todo-tree-pro",
  "displayName": "TODO Tree Pro",
  "version": "0.1.2",
  "private": true,
  "description": "A fast TODO explorer for VS Code with tree/list views, ripgrep-powered scans, and editor highlights.",
  "categories": [
    "Other"
  ],
  "keywords": [
    "comments",
    "productivity",
    "ripgrep",
    "tasks",
    "todo",
    "tree"
  ],
  "homepage": "https://github.com/ywenhao/todo-tree-pro#readme",
  "bugs": {
    "url": "https://github.com/ywenhao/todo-tree-pro/issues"
  },
  "license": "MIT",
  "author": "ywenhao",
  "repository": {
    "type": "git",
    "url": "https://github.com/ywenhao/todo-tree-pro.git"
  },
  "publisher": "todo-tree-pro",
  "type": "module",
  "main": "./dist/extension.mjs",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "build": "npm run package",
    "compile": "tsdown",
    "watch": "tsdown --watch",
    "check": "tsc --noEmit -p ./",
    "package": "npx @vscode/vsce package",
    "package:win32-x64": "node scripts/package-target.mjs win32-x64",
    "package:win32-arm64": "node scripts/package-target.mjs win32-arm64",
    "package:linux-x64": "node scripts/package-target.mjs linux-x64",
    "package:linux-arm64": "node scripts/package-target.mjs linux-arm64",
    "package:linux-armhf": "node scripts/package-target.mjs linux-armhf",
    "package:darwin-x64": "node scripts/package-target.mjs darwin-x64",
    "package:darwin-arm64": "node scripts/package-target.mjs darwin-arm64",
    "package:all": "npm run package:win32-x64 && npm run package:win32-arm64 && npm run package:linux-x64 && npm run package:linux-arm64 && npm run package:linux-armhf && npm run package:darwin-x64 && npm run package:darwin-arm64",
    "publish": "npx @vscode/vsce publish",
    "publish:all": "npx @vscode/vsce publish --target win32-x64 --target win32-arm64 --target linux-x64 --target linux-arm64 --target linux-armhf --target darwin-x64 --target darwin-arm64 --target alpine-x64 --target alpine-arm64",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "npm run compile && vitest run"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/vscode": "^1.101.0",
    "@vscode/vsce": "^3.9.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "reactive-vscode": "^1.0.2",
    "tsdown": "^0.22.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7"
  },
  "contributes": {
    "commands": [
      {
        "command": "todoTreePro.refresh",
        "title": "Refresh",
        "category": "TODO Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "todoTreePro.viewAsTree",
        "title": "Tree",
        "category": "TODO Tree",
        "icon": "$(list-tree)"
      },
      {
        "command": "todoTreePro.viewAsList",
        "title": "List",
        "category": "TODO Tree",
        "icon": "$(list-flat)"
      },
      {
        "command": "todoTreePro.openTodo",
        "title": "Open TODO",
        "category": "TODO Tree"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "todoTreePro",
          "title": "TODO Tree",
          "icon": "resources/activity.svg"
        }
      ]
    },
    "views": {
      "todoTreePro": [
        {
          "id": "todoTreePro.explorer",
          "name": "TODOs",
          "icon": "resources/activity.svg",
          "contextualTitle": "TODO Tree"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "todoTreePro.viewAsTree",
          "when": "view == todoTreePro.explorer && todoTreePro.viewMode != tree",
          "group": "navigation@1"
        },
        {
          "command": "todoTreePro.viewAsList",
          "when": "view == todoTreePro.explorer && todoTreePro.viewMode != list",
          "group": "navigation@2"
        },
        {
          "command": "todoTreePro.refresh",
          "when": "view == todoTreePro.explorer",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "todoTreePro.openTodo",
          "when": "view == todoTreePro.explorer && viewItem == todo",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "TODO Tree Pro",
      "properties": {
        "todoTreePro.excludeFolders": {
          "type": "array",
          "default": [
            ".git",
            ".output",
            ".out",
            "node_modules",
            "dist",
            "build",
            ".next",
            "coverage"
          ],
          "items": {
            "type": "string"
          },
          "description": "Folder names excluded from TODO scans wherever they appear in the workspace."
        },
        "todoTreePro.collapsedFolders": {
          "type": "array",
          "default": [
            ".agents",
            "skills"
          ],
          "items": {
            "type": "string"
          },
          "description": "Folder names collapsed by default in the tree view."
        },
        "todoTreePro.useGitignore": {
          "type": "boolean",
          "default": true,
          "description": "Respect workspace .gitignore patterns when scanning TODOs."
        },
        "todoTreePro.maxFileSize": {
          "type": "number",
          "default": 5242880,
          "minimum": 1024,
          "description": "Maximum file size in bytes for parsing TODO matches after ripgrep finds a candidate file."
        },
        "todoTreePro.highlight.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Highlight TODO and TODO: matches in visible editors."
        },
        "todoTreePro.scanOnTextChange": {
          "type": "boolean",
          "default": true,
          "description": "Update the TODO view from unsaved text buffer changes."
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#101722",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "allowScripts": {
    "@vscode/vsce-sign@2.0.9": true,
    "keytar@7.9.0": true
  }
}

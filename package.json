{
  "name": "todo-tree-pro",
  "displayName": "TODO Tree Pro",
  "version": "0.0.2",
  "private": true,
  "description": "A fast TODO explorer for VS Code with tree/list views, ripgrep-powered scans, and editor highlights.",
  "categories": [
    "Other"
  ],
  "keywords": [
    "comments",
    "productivity",
    "ripgrep",
    "tasks",
    "todo",
    "tree"
  ],
  "homepage": "https://github.com/ywenhao/todo-tree-pro#readme",
  "bugs": {
    "url": "https://github.com/ywenhao/todo-tree-pro/issues"
  },
  "license": "MIT",
  "author": "ywenhao",
  "repository": {
    "type": "git",
    "url": "https://github.com/ywenhao/todo-tree-pro.git"
  },
  "publisher": "todo-tree-pro",
  "type": "module",
  "main": "./dist/extension.mjs",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "build": "npm run package",
    "compile": "tsdown",
    "watch": "tsdown --watch",
    "check": "tsc --noEmit -p ./",
    "ext:publish": "vsce publish",
    "package": "vsce package",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "npm run compile && vitest run"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/vscode": "^1.101.0",
    "@vscode/vsce": "^3.9.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "reactive-vscode": "^1.0.2",
    "tsdown": "^0.22.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7"
  },
  "contributes": {
    "commands": [
      {
        "command": "reactiveTodoTree.refresh",
        "title": "Refresh",
        "category": "TODO Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "reactiveTodoTree.viewAsTree",
        "title": "Tree",
        "category": "TODO Tree",
        "icon": "$(list-tree)"
      },
      {
        "command": "reactiveTodoTree.viewAsList",
        "title": "List",
        "category": "TODO Tree",
        "icon": "$(list-flat)"
      },
      {
        "command": "reactiveTodoTree.openTodo",
        "title": "Open TODO",
        "category": "TODO Tree"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "reactiveTodoTree",
          "title": "TODO Tree",
          "icon": "resources/activity.svg"
        }
      ]
    },
    "views": {
      "reactiveTodoTree": [
        {
          "id": "reactiveTodoTree.explorer",
          "name": "TODOs",
          "icon": "resources/activity.svg",
          "contextualTitle": "TODO Tree"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "reactiveTodoTree.viewAsTree",
          "when": "view == reactiveTodoTree.explorer && reactiveTodoTree.viewMode != tree",
          "group": "navigation@1"
        },
        {
          "command": "reactiveTodoTree.viewAsList",
          "when": "view == reactiveTodoTree.explorer && reactiveTodoTree.viewMode != list",
          "group": "navigation@2"
        },
        {
          "command": "reactiveTodoTree.refresh",
          "when": "view == reactiveTodoTree.explorer",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "reactiveTodoTree.openTodo",
          "when": "view == reactiveTodoTree.explorer && viewItem == todo",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Reactive TODO Tree",
      "properties": {
        "reactiveTodoTree.excludeGlobs": {
          "type": "array",
          "default": [
            "**/.git/**",
            "**/node_modules/**",
            "**/dist/**",
            "**/build/**",
            "**/.next/**",
            "**/coverage/**"
          ],
          "items": {
            "type": "string"
          },
          "description": "Glob patterns excluded from TODO scans."
        },
        "reactiveTodoTree.maxFileSize": {
          "type": "number",
          "default": 5242880,
          "minimum": 1024,
          "description": "Maximum file size in bytes for parsing TODO matches after ripgrep finds a candidate file."
        },
        "reactiveTodoTree.highlight.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Highlight TODO and TODO: matches in visible editors."
        },
        "reactiveTodoTree.scanOnTextChange": {
          "type": "boolean",
          "default": true,
          "description": "Update the TODO view from unsaved text buffer changes."
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#101722",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "allowScripts": {
    "@vscode/vsce-sign@2.0.9": true,
    "keytar@7.9.0": true
  }
}

{
  "name": "todo-tree-pro",
  "displayName": "TODO Tree Pro",
  "version": "0.0.1",
  "private": true,
  "description": "A fast TODO explorer for VS Code with tree/list views, ripgrep-powered scans, and editor highlights.",
  "icon": "resources/icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "todo",
    "tree",
    "comments",
    "tasks",
    "ripgrep",
    "productivity"
  ],
  "galleryBanner": {
    "color": "#101722",
    "theme": "dark"
  },
  "publisher": "ywenhao",
  "author": "ywenhao",
  "repository": {
    "type": "git",
    "url": "https://github.com/ywenhao/todo-tree-pro.git"
  },
  "homepage": "https://github.com/ywenhao/todo-tree-pro#readme",
  "bugs": {
    "url": "https://github.com/ywenhao/todo-tree-pro/issues"
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "check": "tsc --noEmit -p ./",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "pnpm run compile && node out/test/commentParser.test.js && node scripts/check-ripgrep.js"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0",
    "reactive-vscode": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/vscode": "^1.101.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "^5.8.3"
  },
  "contributes": {
    "commands": [
      {
        "command": "reactiveTodoTree.refresh",
        "title": "Refresh",
        "category": "TODO Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "reactiveTodoTree.viewAsTree",
        "title": "Tree",
        "category": "TODO Tree",
        "icon": "$(list-tree)"
      },
      {
        "command": "reactiveTodoTree.viewAsList",
        "title": "List",
        "category": "TODO Tree",
        "icon": "$(list-flat)"
      },
      {
        "command": "reactiveTodoTree.openTodo",
        "title": "Open TODO",
        "category": "TODO Tree"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "reactiveTodoTree",
          "title": "TODO Tree",
          "icon": "resources/activity.svg"
        }
      ]
    },
    "views": {
      "reactiveTodoTree": [
        {
          "id": "reactiveTodoTree.explorer",
          "name": "TODOs",
          "icon": "resources/activity.svg",
          "contextualTitle": "TODO Tree"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "reactiveTodoTree.viewAsTree",
          "when": "view == reactiveTodoTree.explorer && reactiveTodoTree.viewMode != tree",
          "group": "navigation@1"
        },
        {
          "command": "reactiveTodoTree.viewAsList",
          "when": "view == reactiveTodoTree.explorer && reactiveTodoTree.viewMode != list",
          "group": "navigation@2"
        },
        {
          "command": "reactiveTodoTree.refresh",
          "when": "view == reactiveTodoTree.explorer",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "reactiveTodoTree.openTodo",
          "when": "view == reactiveTodoTree.explorer && viewItem == todo",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Reactive TODO Tree",
      "properties": {
        "reactiveTodoTree.excludeGlobs": {
          "type": "array",
          "default": [
            "**/.git/**",
            "**/node_modules/**",
            "**/dist/**",
            "**/build/**",
            "**/.next/**",
            "**/coverage/**"
          ],
          "items": {
            "type": "string"
          },
          "description": "Glob patterns excluded from TODO scans."
        },
        "reactiveTodoTree.maxFileSize": {
          "type": "number",
          "default": 5242880,
          "minimum": 1024,
          "description": "Maximum file size in bytes for parsing TODO matches after ripgrep finds a candidate file."
        },
        "reactiveTodoTree.highlight.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Highlight TODO and TODO: matches in visible editors."
        },
        "reactiveTodoTree.scanOnTextChange": {
          "type": "boolean",
          "default": true,
          "description": "Update the TODO view from unsaved text buffer changes."
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "engines": {
    "vscode": "^1.101.0"
  },
  "packageManager": "pnpm@11.4.0"
}
